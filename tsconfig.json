{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "noImplicitAny": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "types": [
      "node",
      "@playwright/test"
    ],
    "baseUrl": ".",
    "paths": {
      "@fixtures": [
        "fixtures/index.ts"
      ],
      "@pages/*": [
        "pages/*"
      ],
      "@utils/*": [
        "utils/*"
      ]
    }
  },
  "include": [
    "playwright.config.ts",
    "global-setup.ts",
    "fixtures/**/*.ts",
    "pages/**/*.ts",
    "tests/**/*.ts",
    "utils/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "playwright-report",
    "test-results",
    "reports",
    ".auth"
  ]
}
